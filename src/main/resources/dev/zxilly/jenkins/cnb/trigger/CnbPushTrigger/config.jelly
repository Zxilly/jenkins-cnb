<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">
  <f:entry title="CNB server ID" field="serverId">
    <f:select />
  </f:entry>
  <f:entry title="Repository path" field="repositoryPath">
    <f:textbox />
  </f:entry>
  <f:entry title="Branch or tag filter" field="branchFilter">
    <f:textbox default="**" />
  </f:entry>
</j:jelly>
