<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">
  <f:section title="CNB servers">
    <f:entry help="${rootURL}/plugin/cnb/help/servers.html">
      <f:repeatableProperty field="servers" minimum="1" />
    </f:entry>
  </f:section>
  <f:section title="Organization Folder consistency">
    <f:entry title="Periodically rescan CNB Organization Folders" field="organizationReconciliationEnabled">
      <f:checkbox default="true" />
    </f:entry>
    <f:entry title="Full rescan interval (seconds)" field="organizationReconciliationIntervalSeconds">
      <f:number min="900" max="86400" default="21600" />
    </f:entry>
  </f:section>
</j:jelly>
