<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">
  <f:entry title="CNB server" field="serverId">
    <f:select />
  </f:entry>
  <f:entry title="Repository" field="repository">
    <f:textbox placeholder="owner/repository" />
  </f:entry>
  <f:entry title="Commit repository (forks)" field="commitRepository">
    <f:textbox placeholder="Defaults to Repository" />
  </f:entry>
  <f:entry title="Commit SHA" field="sha">
    <f:textbox />
  </f:entry>
  <f:entry title="Pull request number" field="pullRequestNumber">
    <f:textbox />
  </f:entry>
  <f:entry title="Context" field="context">
    <f:textbox placeholder="Defaults to the Jenkins job name" />
  </f:entry>
  <f:entry title="Reporting credentials" field="credentialsId">
    <f:select />
  </f:entry>
</j:jelly>
